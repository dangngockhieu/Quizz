generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ENUMS

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum QuizTypeResult {
  AVERAGE
  BEST
  LATEST
}

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  password     String
  fullName     String
  refreshToken String?
  role         Role
  status       UserStatus @default(ACTIVE)

  classes  UserClass[]
  attempts Attempt[]

  @@map("users")
}

model Class {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  users        UserClass[]
  classQuizzes ClassQuiz[]

  @@map("classes")
}

model UserClass {
  userID  Int
  classID Int

  user  User  @relation(fields: [userID], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classID], references: [id], onDelete: Cascade)

  @@id([userID, classID])
  @@map("user_classes")
}

model Quiz {
  id           Int            @id @default(autoincrement())
  title        String
  description  String?
  timeStart    DateTime
  timeEnd      DateTime
  timeLimit    Int
  typeResult   QuizTypeResult
  countAttempt Int            @default(1)

  questions    Question[]
  attempts     Attempt[]
  classQuizzes ClassQuiz[]

  @@map("quizzes")
}

model ClassQuiz {
  classID Int
  quizID  Int

  class Class @relation(fields: [classID], references: [id], onDelete: Cascade)
  quiz  Quiz  @relation(fields: [quizID], references: [id], onDelete: Cascade)

  @@id([classID, quizID])
  @@map("class_quizzes")
}

model Question {
  id      Int          @id @default(autoincrement())
  quizID  Int
  content String
  type    QuestionType

  quiz    Quiz            @relation(fields: [quizID], references: [id], onDelete: Cascade)
  options Option[]
  answers AttemptAnswer[]

  @@map("questions")
}

model Option {
  id         Int     @id @default(autoincrement())
  questionID Int
  content    String
  isCorrect  Boolean

  question Question        @relation(fields: [questionID], references: [id], onDelete: Cascade)
  answers  AttemptAnswer[]

  @@map("options")
}

model Attempt {
  id        Int      @id @default(autoincrement())
  userID    Int
  quizID    Int
  score     Float
  timeStart DateTime
  timeEnd   DateTime

  user User @relation(fields: [userID], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizID], references: [id], onDelete: Cascade)

  answers AttemptAnswer[]

  @@index([userID, quizID])
  @@map("attempts")
}

model AttemptAnswer {
  id         Int @id @default(autoincrement())
  attemptID  Int
  questionID Int
  optionID   Int

  isCorrect Boolean?
  score     Float?

  attempt  Attempt  @relation(fields: [attemptID], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionID], references: [id], onDelete: Cascade)
  option   Option   @relation(fields: [optionID], references: [id])

  @@unique([attemptID, questionID])
  @@map("attempt_answers")
}
